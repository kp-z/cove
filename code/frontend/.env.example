# Cove Frontend Environment Variables
# Copy this file to .env.local for local development overrides

# API URL (optional - auto-detected if not set)
# Development default: http://localhost:3001
# Production: auto-detects from window.location
# VITE_API_URL=http://your-server-ip:3001

# WebSocket URL (optional - auto-detected if not set)
# Development default: ws://localhost:3001
# Production: auto-detects from window.location (ws:// or wss://)
# VITE_WS_URL=ws://your-server-ip:3001

# Example for custom backend port:
# VITE_API_URL=http://192.168.1.100:3001
# VITE_WS_URL=ws://192.168.1.100:3001

# Example for HTTPS deployment:
# VITE_API_URL=https://api.example.com
# VITE_WS_URL=wss://api.example.com
