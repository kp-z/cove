{
  "name": "@cove/backend",
  "version": "1.0.0",
  "description": "Cove Backend - Unified test configuration for all backend layers",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "npm run build:esbuild && node dist/bundle.js",
    "dev": "nodemon --watch src --ext ts --exec 'npm run build:esbuild && node dist/bundle.js'",
    "build": "tsc",
    "build:esbuild": "esbuild src/main.ts --bundle --platform=node --format=esm --outfile=dist/bundle.js --packages=external",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint . --ext .ts",
    "type-check": "tsc --noEmit",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio"
  },
  "keywords": [
    "backend",
    "ddd",
    "testing"
  ],
  "author": "Cove Team",
  "license": "MIT",
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/proper-lockfile": "^4.1.4",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.2.0",
    "@vitest/ui": "^1.2.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.56.0",
    "nodemon": "^3.1.14",
    "prisma": "^6.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@prisma/client": "^6.1.0",
    "@trpc/client": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "@types/ws": "^8.18.1",
    "deepmerge": "^4.3.1",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "openai": "^6.37.0",
    "proper-lockfile": "^4.1.2",
    "trpc-ui": "^1.0.15",
    "ws": "^8.20.1",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  }
}
