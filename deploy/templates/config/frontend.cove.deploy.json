{
  "version": "1.0",
  "type": "frontend",
  "runtime": {
    "type": "node",
    "version": "20"
  },
  "build": {
    "command": "npm run build",
    "outputDir": "dist",
    "env": {
      "VITE_API_URL": "${BACKEND_URL}"
    }
  },
  "serve": {
    "type": "static",
    "port": 80,
    "spa": true,
    "headers": {
      "Cache-Control": "public, max-age=31536000, immutable"
    }
  },
  "resources": {
    "memory": "256M",
    "cpu": "0.5"
  }
}
